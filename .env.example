# ADSb-Vue configuration — copy to ".env" and edit as needed.
#
# Comments must be on their own line (a line starting with #). Do NOT put an
# inline comment after a value — both docker-compose's env_file and simple
# parsers keep everything after "=" as the value, so "FOO=1.5  # note" would set
# FOO to "1.5  # note".
#
# server.py auto-loads a .env in its directory; real environment variables and
# docker-compose `environment:` entries take precedence over this file.

# Base URL of your tar1090 / Ultrafeeder instance.
# Use http://127.0.0.1 when running on the same host as the feeder.
ADSB_ULTRAFEEDER=http://127.0.0.1

# Web-UI port the viewer listens on. This is NOT an ADS-B data port — the data
# source is the URL in ADSB_ULTRAFEEDER above. (ADSB_PORT is a back-compat alias.)
ADSB_WEB_PORT=24556

# Receiver location. Leave unset to auto-detect from tar1090's
# /data/receiver.json (recommended).
#ADSB_RECV_LAT=44.0
#ADSB_RECV_LON=-93.0

# How many newest history chunks to read (0 = all available history).
# More chunks = wider coverage envelope but slower first load.
ADSB_MAX_CHUNKS=48

# Seconds to cache parsed observations before a rebuild.
ADSB_CACHE_SECS=120

# De-dup resolution: coarse on purpose (this is a coverage map, not a replay).
# Horizontal grid cell size, nautical miles:
ADSB_CELL_NM=1.5
# Altitude bin size, feet:
ADSB_ALT_BIN_FT=1000

# Discard positions farther than this, nautical miles (bad data / MLAT):
ADSB_MAX_RANGE_NM=400
# "Low altitude" cutoff for the low-altitude range stat, feet:
ADSB_LOW_ALT_FT=10000

# Parallel chunk downloads. Higher helps a lot when the feeder is remote /
# high-latency; on the same host it barely matters. 1 = old serial behaviour.
ADSB_FETCH_WORKERS=8

# Antenna height above ground, feet (your mast). Feeds the terrain line-of-sight
# horizon model; the ground elevation is read from the terrain automatically.
ADSB_ANTENNA_AGL_FT=30

# Ground elevation of the receiver site, feet MSL. Only needed for the
# ADSB_LOS_FILTER below (the terrain compare/predicted-horizon feature reads
# ground elevation from the DEM tiles directly and doesn't use this).
# ADSB_ANTENNA_ELEV_FT=0

# Optional server-side 4/3-earth line-of-sight filter. When enabled, drops any
# observation whose distance exceeds the physically-possible LOS range for
# its reported altitude, i.e. dist > 1.23 * (sqrt(alt_ft) + sqrt(antenna_MSL_ft)) * 1.15.
# Useful if your upstream decoder occasionally accepts weak signals with bit-
# corrupted altitude fields — those show up as far low-altitude cells that
# can't physically exist. Off by default; set both this AND ADSB_ANTENNA_ELEV_FT
# for the filter to be tight (without ELEV, antenna is treated as sea level).
# ADSB_LOS_FILTER=true

# Appearance. State border colours (hex); the home state(s) get their own colour.
ADSB_BORDER_COLOR=#3f82b8
ADSB_HOME_BORDER_COLOR=#6fd6c0
# Distance fade as you zoom out. Set to 0 to disable the fade entirely.
ADSB_FOG_DENSITY=0.0012

# Long-term persistence (optional). Point this at a mapped volume and coverage
# accumulates in <dir>/adsbvue.db across restarts, and cities.local.json is read
# from <dir> first (live-editable). Leave unset for no persistence.
#ADSB_DATA_DIR=/data
# Store retention: drop cells not heard within this many days (0 = keep everything).
#ADSB_RETAIN_DAYS=30

# HeyWhatsThat range rings (optional). Set your panorama id (the same one your
# Ultrafeeder uses) and the Terrain panel gains an "HWT range rings" toggle —
# the rings are fetched once and cached. Must be a panorama for this receiver.
#ADSB_HEYWHATSTHAT_ID=ABCD1234
# Ring altitudes in feet, comma-separated.
#ADSB_HEYWHATSTHAT_ALTS_FT=10000,40000
